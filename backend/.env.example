# Copy this to .env and fill in your values

# ─── Database (from Neon.tech dashboard) ─────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_SYNC_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── App ─────────────────────────────────────────────────────────────
APP_ENV=production
APP_SECRET_KEY=change-this-to-a-random-string-in-production

# ─── CORS (your Vercel frontend URL) ─────────────────────────────────
CORS_ORIGINS=https://ddi-predict.vercel.app,http://localhost:5173

# ─── Model Paths ─────────────────────────────────────────────────────
MODEL_PATH=model_artifacts/rf_model.pkl
MODEL_META_PATH=model_artifacts/model_meta.json

# ─── Dataset Paths ────────────────────────────────────────────────────
# Render: dataset is in /app/dataset/ (relative to repo root)
MERGED_DATA_PATH=../dataset/merged_data/merged_data.csv
TRAIN_DATA_PATH=../dataset/train_data/train_set.csv

# ─── Encoding ────────────────────────────────────────────────────────
PYTHONIOENCODING=utf-8
